{
  "name": "school-saas-backend",
  "version": "1.0.0",
  "description": "School Management SaaS - Node.js Backend",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:migrate": "node src/db/migrate.js",
    "db:seed": "node src/db/seed.js",
    "db:migrate:v2": "node src/db/migrate-v2.js",
    "db:migrate:v3": "node src/db/migrate-v3.js",
    "db:migrate-fix": "node src/db/migrate-fix.js",
    "db:reset": "node src/db/migrate.js && node src/db/migrate-v2.js && node src/db/seed.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1042.0",
    "@aws-sdk/s3-request-presigner": "^3.1042.0",
    "@sendgrid/mail": "^8.1.6",
    "@sentry/node": "^10.51.0",
    "@sparticuz/chromium": "^148.0.0",
    "aws-sdk": "^2.1693.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.3.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.7",
    "pdf-lib": "^1.17.1",
    "pg": "^8.11.3",
    "puppeteer-core": "^24.42.0",
    "redis": "^5.12.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "stripe": "^22.1.0",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
